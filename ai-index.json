---
layout: none
permalink: /ai-index.json
---
{
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "Lagerland Apps — Structured App Index",
  "description": "Machine-readable metadata for every live app in the Lagerland Apps catalogue. Auto-regenerated on every site build from source frontmatter.",
  "url": "{{ site.url }}/ai-index.json",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "dateModified": "{{ site.time | date: "%Y-%m-%d" }}",
  "publisher": {
    "@type": "Organization",
    "name": "Lagerland Apps",
    "url": "{{ site.url }}",
    "email": "lagerland.apps@proton.me",
    "description": "Independent Apple developer building privacy-first iOS and macOS apps. No tracking, no ads, no accounts.",
    "sameAs": [
      "https://apps.apple.com/developer/antti-aittamaa/id1855943133",
      "https://github.com/lagerland-apps"
    ]
  },
  "privacy_philosophy": {
    "third_party_tracking": false,
    "advertising": false,
    "account_required": false,
    "data_storage": "local-first",
    "monetization_models": ["one-time purchase", "subscription", "freemium"]
  },
  "apps": [
  {%- assign live_apps = site.apps | where: "status", "live" -%}
  {%- assign first = true -%}
  {%- for app in live_apps -%}
    {%- unless first -%},{%- endunless -%}
    {
      "name": {{ app.name | jsonify }},
      "slug": {{ app.slug | jsonify }},
      "url": "{{ site.url }}{{ app.url }}",
      "app_store_url": {{ app.app_store_url | jsonify }},
      "tagline": {{ app.tagline | jsonify }},
      "category": {{ app.category | jsonify }},
      "platforms": {{ app.platforms | jsonify }},
      "description": {{ app.seo.description | default: app.tagline | jsonify }},
      "headline": {{ app.hero.headline | jsonify }},
      "positioning": {{ app.hero.subheadline | jsonify }},
      "keywords": {{ app.seo.keywords | default: empty | jsonify }},
      "pricing": {
        "model": {{ app.price.model | jsonify }},
        "display": {{ app.price.value | jsonify }},
        "schema_price_eur": {{ app.schema_price | default: "0" | jsonify }}
      },
      "privacy": {
        "third_party_tracking": {% if app.privacy.tracking %}true{% else %}false{% endif %},
        "account_required": {% if app.privacy.account_required %}true{% else %}false{% endif %},
        "data_collection": {{ app.privacy.data_collection | default: "none" | jsonify }},
        "notes": {{ app.privacy.notes | default: empty | jsonify }}
      },
      "features": [
        {%- if app.features -%}
        {%- for f in app.features -%}
          {"title": {{ f.title | jsonify }}, "description": {{ f.description | jsonify }}}{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
        {%- endif -%}
      ],
      "value_points": [
        {%- if app.value_points -%}
        {%- for v in app.value_points -%}
          {"title": {{ v.title | jsonify }}, "description": {{ v.description | jsonify }}}{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
        {%- endif -%}
      ],
      "who_for": {{ app.who_for | default: empty | jsonify }},
      "who_not_for": {{ app.who_not_for | default: empty | jsonify }},
      "alternatives_to": {{ app.alternatives_to | default: empty | jsonify }},
      {%- assign extra = site.data.app_enrichment[app.slug] -%}
      "use_cases": {{ extra.use_cases | default: empty | jsonify }},
      "pricing_tiers": {{ extra.pricing_tiers | default: empty | jsonify }},
      "languages": {{ extra.languages | default: empty | jsonify }},
      {%- if app.ratings and app.ratings.count and app.ratings.count != 0 -%}
      "rating": {
        "value": {{ app.ratings.value | jsonify }},
        "count": {{ app.ratings.count | jsonify }},
        "last_synced": {{ app.ratings.last_synced | jsonify }}
      },
      {%- endif -%}
      "faq": [
        {%- if app.faq -%}
        {%- for q in app.faq -%}
          {"question": {{ q.q | jsonify }}, "answer": {{ q.a | jsonify }}}{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
        {%- endif -%}
      ],
      "release": {
        "first_release": {{ app.release.first_release | default: "" | jsonify }},
        "last_updated": {{ app.release.last_updated | default: "" | jsonify }}
      }
    }
    {%- assign first = false -%}
  {%- endfor -%}
  ]
}
