---
permalink: /feed.xml
layout: none
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>Lagerland Apps — Journal</title>
  <subtitle>Rebrand stories, shipping notes, and essays about building privacy-first Apple apps as a one-person studio.</subtitle>
  <link href="{{ site.url }}/feed.xml" rel="self"/>
  <link href="{{ site.url }}/journal/"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ site.url }}/</id>
  <author>
    <name>Antti Aittamaa</name>
    <email>lagerland.apps@proton.me</email>
    <uri>{{ site.url }}/lagerland-apps/</uri>
  </author>
  <rights>&#169; {{ "now" | date: "%Y" }} Lagerland Apps</rights>
  <icon>{{ site.url }}/assets/icons/lagerland-mark.png</icon>
  <logo>{{ site.url }}/assets/icons/lagerland-mark.png</logo>
{%- assign posts = site.journal | sort: "date" | reverse -%}
{% for post in posts %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ post.url }}" rel="alternate" type="text/html"/>
    <id>{{ site.url }}{{ post.url }}</id>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_updated | default: post.date | date_to_xmlschema }}</updated>
    <author>
      <name>Antti Aittamaa</name>
      <uri>{{ site.url }}/lagerland-apps/</uri>
    </author>
    {% if post.lede %}<summary type="html">{{ post.lede | xml_escape }}</summary>{% endif %}
    <content type="html">{{ post.content | xml_escape }}</content>
  </entry>
{% endfor %}
</feed>
